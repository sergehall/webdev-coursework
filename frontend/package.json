{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "start:dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build:bundle": "vite build",
    "build:fast": "yarn build:bundle",
    "build": "yarn typecheck && yarn build:bundle",
    "install:strict": "yarn install --immutable",
    "build:css": "tailwindcss -i ./src/index.css -o ./dist/output.css --watch",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint src --fix",
    "check": "tsc --noEmit && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "generate:favicons": "node scripts/generate-favicons.mjs"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@floating-ui/react-dom": "^2.1.8",
    "@sentry/browser": "^10.53.1",
    "@sentry/react": "^10.53.1",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "esprima": "^4.0.1",
    "estraverse": "^5.3.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-circular-progressbar": "^2.2.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/esprima": "^4.0.6",
    "@types/estraverse": "^5.1.7",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@typescript-eslint/types": "^8.59.3",
    "@typescript-eslint/utils": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.29",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vercel": "^54.1.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "whatwg-fetch": "^3.6.20"
  }
}
