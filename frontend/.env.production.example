# Production environment variables for Heroku Config Vars
#
# Required — set this in Heroku dashboard or via:
#   heroku config:set VITE_QUIZ_SECRET=your-secret --app your-app-name
#
VITE_QUIZ_SECRET=your-quiz-secret-here

# Optional — only needed when the API runs on a different origin than the frontend.
# Leave unset (or empty) when frontend and backend share the same domain/dyno.
#   heroku config:set VITE_API_URL=https://api.example.com --app your-app-name
#
# VITE_API_URL=https://api.webdev-coursework.com

# Optional — Sentry error tracking DSN.
# VITE_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
