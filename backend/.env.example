# App
PORT=5050
NODE_ENV=development
ALLOWED_ORIGINS=https://webdev-coursework.com,https://api.webdev-coursework.com,http://localhost:5173,http://localhost:5050

# Database (single source of truth)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/webdev_coursework
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Auth / guards
QUIZ_SECRET_KEY=change_me_quiz_secret
QUIZ_ANSWERS_JWT_SECRET=change_me_quiz_jwt_secret
QUIZ_ANSWERS_JWT_TTL=1h
QUIZ_JWT_ISSUER=webdev-coursework
QUIZ_JWT_AUDIENCE=webdev-coursework-users
ADMIN_API_KEY=change_me_admin_key

# Optional release label for local/dev UI
RELEASE_VERSION=local-dev
